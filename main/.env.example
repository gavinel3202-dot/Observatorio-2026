# Configuración opcional de Firebase.
# Si no defines estas variables, la app funciona usando el almacenamiento
# local del navegador (localStorage).

# --- Opción A: un único JSON (en una sola línea) ---
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
VITE_FIREBASE_CONFIG=

# --- Opción B: variables sueltas (compatibles con Vercel) ---
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Identificador de la aplicación (usado en la ruta de Firestore).
VITE_APP_ID=icfg-app-id
